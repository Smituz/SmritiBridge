{
  "manifest_version": 3,
  "name": "SmritiBridge 2.0",
  "version": "2.0",
  "description": "Transfer AI chat context across AI tools",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["storage_bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": [
        "extractors/chatgpt.js",
        "core/contextSchema.js",
        "core/importanceScoring.js",
        "core/compression.js",
        "core/heuristics.js",
        "core/contextBuilder.js",
        "content_script.js",
        "/popup/popup.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ] 
}